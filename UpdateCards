name: Update README cards

on:
  schedule:
    - cron: "0 0 * * *" # Runs once daily at midnight
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest

    permissions:
      contents: write

    steps:
      - uses: actions/checkout@v4

      - name: Generate stats card
        run: |
          mkdir -p profile
          curl -o profile/stats.svg "https://github-readme-stats.vercel.app/api?username=${{ github.repository_owner }}&show_icons=true&theme=default&cache_buster=${{ github.run_id }}"

      - name: Generate top languages card
        run: |
          mkdir -p profile
          curl -o profile/languages.svg "https://github-readme-stats.vercel.app/api/top-langs?username=${{ github.repository_owner }}&layout=compact&langs_count=6&cache_buster=${{ github.run_id }}"

      - name: Commit and push changes
        run: |
          git config user.name "github-actions[bot]"
          git config user.email "41898282+github-actions[bot]@users.noreply.github.com"
          git add profile/*.svg 2>/dev/null || true
          git diff --quiet && git diff --staged --quiet || (git commit -m "Update README cards" && git push origin main)
